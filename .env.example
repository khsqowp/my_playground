# Database
DATABASE_URL="mysql://motorcycle:password@localhost:3306/motorcycle_db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# Initial Admin Account
ADMIN_EMAIL="admin@88motorcycle.com"
ADMIN_PASSWORD="changeme"
ADMIN_NAME="Admin"

# AI (Optional)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# File Upload
UPLOAD_MAX_SIZE_MB=10
UPLOAD_DIR="./public/uploads"

# External RAG file archive
RAG_DATA_ROOT_HOST="/Volumes/SSD T7/AI/data"
RAG_SERVICE_URL="http://host.docker.internal:8088"
RAG_DEFAULT_PROJECT="inbox"
